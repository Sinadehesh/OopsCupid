// Add these to your existing schema.prisma

model AssessmentSession {
  id                String   @id @default(cuid())
  userId            String?  // Nullable to allow anonymous use before checkout
  quizName          String   // e.g., "toxic-friend-test"
  status            String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  isPremiumUnlocked Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  answers           AssessmentAnswer[]
  report            PremiumReport?
}

model AssessmentAnswer {
  id                String   @id @default(cuid())
  sessionId         String
  questionId        String
  value             String   // e.g., "3 - Often"
  createdAt         DateTime @default(now())

  session           AssessmentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
}

model PremiumReport {
  id                String   @id @default(cuid())
  sessionId         String   @unique
  riskScore         Int
  impactScore       Int
  tier              Int
  dominantPattern   String
  reportData        Json     // Stores narrative blocks, subscale data, top red flags
  createdAt         DateTime @default(now())

  session           AssessmentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
