generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Lead {
  id               String   @id @default(cuid())
  email            String   @unique
  quizType         String
  rawAnswers       Json?    
  profileData      Json?    
  coachingClaimed  Boolean  @default(false)
  premiumClicked   Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model WorkbookEntry {
  id          String   @id @default(cuid())
  workbook    String   // e.g. "anxious-attachment"
  week        Int
  day         Int
  exerciseKey String   // e.g. "integration-reflection", "threat-decoder"
  content     Json     // flexible: text, flipped cards, slider values etc.
  sessionId   String?  // anonymous session identifier
  createdAt   DateTime @default(now())
}
