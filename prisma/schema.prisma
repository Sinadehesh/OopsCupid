generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url is removed here for Prisma 7 compatibility
}

model Lead {
  id               String   @id @default(cuid())
  email            String   @unique
  quizType         String
  rawAnswers       Json?    
  profileData      Json?    
  coachingClaimed  Boolean  @default(false)
  createdAt        DateTime @default(now())
}
